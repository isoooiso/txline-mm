# Network: mainnet | devnet (selects base URL, programId, txlMint defaults)
TXLINE_NETWORK=devnet

# Solana RPC endpoint (Helius recommended)
TXLINE_RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_KEY

# Wallet secret key — base58 string or JSON byte array
WALLET_SECRET_KEY=

# Optional: filter World Cup fixtures by competition ID (otherwise matched by name)
# WORLD_CUP_COMPETITION_ID=

# --- AI Pundit Bot (Telegram fan alerts) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
VOICE_ENABLED=false
EDGE_TTS_VOICE=en-US-GuyNeural
ANTHROPIC_API_KEY=
# Optional: override LLM model (default claude-haiku-4-5-20251001)
# ANTHROPIC_MODEL=
